<launch>

    <!-- Launch Arguments -->
    <arg name="map_name" default="small_house"/>
    <arg name="use_sim_time" default="true"/>

    <!-- Map path -->
    <let name="map_path"
         value="$(find-pkg-share robot_maps)/maps/$(var map_name)/map.yaml"/>

    <let name="amcl_config_path" value="$(find-pkg-share program_bringup)/config/amcl.yaml"/>

     <!-- TF publisher  -->

    <!-- Nav2 Map Server -->
    <node pkg="nav2_map_server"
          exec="map_server"
          name="map_server"
          output="screen">
        <param name="yaml_filename" value="$(var map_path)"/>
        <param name="frame_id" value="map"/>
        <param name="use_sim_time" value="$(var use_sim_time)"/>
    </node>

    <!-- Nav2 AMCL(adaptive Monte Carlo Localization) -->
    <node pkg="nav2_amcl"
          exec="amcl"
          name="amcl"
          output="screen">
        <param name="amcl_config" value="$(var amcl_config_path)"/>
        <param name="use_sim_time" value="$(var use_sim_time)"/>
    </node>

    <!-- Lifecycle Manager -->
    <node pkg="nav2_lifecycle_manager"
          exec="lifecycle_manager"
          name="lifecycle_manager_localization"
          output="screen">
        <param name="node_names" value="['map_server', 'amcl']"/>
        <param name="use_sim_time" value="$(var use_sim_time)"/>
        <param name="autostart" value="true"/>
    </node>

    

</launch>