<?xml version="1.0"?>
<robot name="my_robo_v0" xmlns:xacro="https://www.ros.org/wiki/xacro">

    <xacro:include filename="materials.xacro" />
    <xacro:include filename="inertia_descriptions.xacro" />
    <xacro:include filename="camera.xacro" />
    <xacro:include filename="lidar.xacro" />
    <xacro:include filename="ros2_hardwareinterface.xacro" />
    <xacro:include filename="imu_sensor.xacro" />

    <xacro:property name="box_len" value="0.6" />
    <xacro:property name="box_width" value="0.4" />
    <xacro:property name="box_height" value="0.2" />
    <xacro:property name="wheel_radius" value="0.1" />
    <xacro:property name="wheel_thickness" value="0.02" />
    
    <link name="base_footprint">
    </link>

    <link name="base_link">
        <visual>
            <geometry>
                <box size="${box_len} ${box_width} ${box_height}" />
            </geometry>
            <origin xyz="0 0 ${box_height/2}" rpy="0 0 0" />
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                <box size="${box_len} ${box_width} ${box_height}" />
            </geometry>
            <origin xyz="0 0 ${box_height/2}" rpy="0 0 0" />
        </collision>
        <xacro:box_inertia Mass="10.0" x="${box_len}" y="${box_width}" z="${box_height}" arr_xyz="0 0 ${box_height/2}" arr_rpy="0 0 0" />
    </link>

    <xacro:macro name="wheel" params="params">
        <link name="${params}">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_thickness}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
                <material name="grey"/>
            </visual>
            <collision>
                <geometry>
                    <sphere radius="${wheel_radius}"/>
                </geometry>
                <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
            </collision>
            <xacro:cylinder_inertia Mass="1.0" r="${wheel_radius}" h="${wheel_thickness}" arr_xyz="0 0 0" arr_rpy="${pi/2} 0 0"/>
        </link>
    </xacro:macro>
    
    <xacro:wheel params="right_wheel" />
    <xacro:wheel params="left_wheel" />


    <link name="caster_wheel">
        <visual>
            <geometry>
                <sphere radius="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <material name="grey"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </collision>
        <xacro:solid_sphere_inertia Mass="0.5" r="0.05" arr_xyz="0 0 0" arr_rpy="0 0 0"/> 
    </link>

    <joint name="base_right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="${-box_len/4} ${-box_width/2 - wheel_thickness/2} 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="base_left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="${-box_len/4} ${box_width/2 + wheel_thickness/2} 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="base_caster_wheel_joint" type="fixed">
        <parent link="base_link"/>
        <child link="caster_wheel"/>
        <origin xyz="${box_len/4} 0 ${-wheel_radius/2}" rpy="0 0 0"/>
    </joint>



    <joint name="baseshadow_object_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 ${box_height/2}" rpy="0 0 0"/>
    </joint>


    <gazebo>
        <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
            <parameters>/home/chirag/ROS2_WS/src/program_bringup/config/controllers.yaml</parameters>
        </plugin>
    </gazebo>

    <gazebo reference="caster_wheel">
        <mu1 value="0.01" />
        <mu2 value="0.01" />
    </gazebo>

        <!-- Wheels -->
    <gazebo reference="left_wheel">
        <mu1>1000000000000000.0</mu1>
        <mu2>1000000000000000.0</mu2>
        <kp>1000000000000.0</kp>
        <kd>10.0</kd>
        <minDepth>0.001</minDepth>
        <maxVel>0.1</maxVel>
        <fdir1>1 0 0</fdir1>
    </gazebo>

    <gazebo reference="right_wheel">
        <mu1>1000000000000000.0</mu1>
        <mu2>1000000000000000.0</mu2>
        <kp>1000000000000.0</kp>
        <kd>10.0</kd>
        <minDepth>0.001</minDepth>
        <maxVel>0.1</maxVel>
        <fdir1>1 0 0</fdir1>
    </gazebo>

    <gazebo>
        <plugin name='gz::sim::systems::Sensors' filename='gz-sim-sensors-system'>
        <render_engine>ogre2</render_engine>
        </plugin>
        <plugin name='gz::sim::systems::Imu' filename='gz-sim-imu-system'/>
    </gazebo>
    
</robot>